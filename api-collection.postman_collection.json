				{
					"name": "Update User",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"var urlStr = pm.request.url.toString();",
									"var match = urlStr.match(/(https?:\\/\\/[^\\/]+)\\/users\\/(\\d+)/);",
									"if (match) {",
									"    var baseUrl = match[1];",
									"    var userId = match[2];",
									"    if (pm.collectionVariables.get(\"last_loaded_user_id\") !== userId) {",
									"        pm.sendRequest({",
									"            url: baseUrl + \"/users/\" + userId,",
									"            method: 'GET',",
									"            header: {",
									"                'Accept': 'application/json'",
									"            }",
									"        }, function (err, res) {",
									"            if (res && res.code === 200) {",
									"                var json = res.json();",
									"                if (json && json.data) {",
									"                    pm.collectionVariables.set(\"last_loaded_user_id\", userId);",
									"                    var newBody = {",
									"                        name: json.data.name,",
									"                        email: json.data.email",
									"                    };",
									"                    pm.request.body.raw = JSON.stringify(newBody, null, 4);",
									"                }",
									"            }",
									"        });",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Budi Santoso Edit\",\n    \"email\": \"budi.edit@example.com\"\n}"
						},
						"url": {
							"raw": "{{api_gateway_url}}/users/1",
							"host": [
								"{{api_gateway_url}}"
							],
